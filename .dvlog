    t52path = workdirs[length(workdirs)] + "/krc.t52"
    syscall("cp " + t52path + " /tmp/davinci_good.t52")
    printf("Saved from: %s\n", t52path)
}
syscall("ls -lh /tmp/davinci_good.t52")
printf("Davinci: %dx%dx%d\n", dim(out.tsurf)[1], dim(out.tsurf)[2], dim(out.tsurf)[3])
