#!/Applications/davinci.app/Contents/Resources/bin/davinci -f
# Test script to run KRC with same parameters as Python test
# and show the output structure for comparison

# Set up environment variables for KRC
putenv("DV_SCRIPT_FILES","/Users/chaberle/Documents/GitHab/KRC/krc_python/pykrc/data")
putenv("DV_KRC_HOME","/Users/chaberle/Documents/GitHab/KRC")


# Load the KRC davinci interface
source("/Users/chaberle/Documents/GitHab/KRC/krc_python/docs/davinci/krc.dvrc")

# Run KRC with same parameters as Python test: krc(lat=25.)
printf("Running KRC at latitude 25 degrees...\n")
out = krc(lat=25.)

# Save the output to a file for inspection
write(out, "krc_davinci_output.hdf", force=1)
printf("Output saved to krc_davinci_output.hdf\n")

# Check if we got a result
if (HasValue(out) == 0) {
    printf("ERROR: KRC did not return a result\n")
    exit
}

# Check tsurf dimensions
printf("\n=== TSURF DIMENSIONS ===\n")
tsurf_dims = dim(out.tsurf)
printf("Shape: %dx%dx%d\n", tsurf_dims[1], tsurf_dims[2], tsurf_dims[3])

# Show some sample temperature values
printf("\n=== SAMPLE TEMPERATURES ===\n")
printf("Min: %.2f K\n", min(out.tsurf))
printf("Max: %.2f K\n", max(out.tsurf))

# Show temperatures for last season (index 360) across all 96 hours
printf("\n=== LAST SEASON TEMPERATURES (all 96 hours) ===\n")
i = 1
while(i <= 96) {
    temp = out.tsurf[i][1][360]
    printf("Hour %2d: %.2f K\n", i, temp)
    i = i + 1
}

printf("\n=== DONE ===\n")
