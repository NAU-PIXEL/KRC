###Europa###################################################################################
a = krc(N24=24,N1=20,lbound=0,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101,JDISK=1801,N5=2160)
plot(a.tsurf,xaxis=a.depth)                                                               #Insulating

b = krc(N24=24,N1=30,lbound=0,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101,JDISK=1801,N5=2160)
plot(b.tsurf[,:20],xaxis=b.depth[,:20])                                                   #Insulating

c = krc(N24=24,      lbound=0,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101,JDISK=1801,N5=2160)
plot(c.tsurf[,:20],xaxis=c.depth[,:20])                                                   #Insulating

plot(a.tsurf-b.tsurf[,:20],xaxis=a.depth)
plot(a.tsurf-c.tsurf[,:20],xaxis=a.depth)
###Number of layers OK, even with small number

a = krc(N24=24,lbound=0,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101,JDISK=1801,N5=2160)
plot(a.tsurf[,:20],xaxis=a.depth[,:20])                                                   #Insulating

b = krc(N24=24,lbound=0,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101)
plot(b.tsurf[,:20],xaxis=b.depth[,:20])                                                   #Insulating

plot(a.tsurf[,:20]-b.tsurf[,:20],xaxis=a.depth[,:20])
###OK to run with default JDISK=1801,N5=2160

a = krc(N24=24,lbound=0,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101)
plot(a.tsurf[,:20],xaxis=a.depth[,:20])                                                   #Insulating

b = krc(N24=24,KEEP="T",         lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101)
plot(b.tsurf[,:20],xaxis=b.depth[,:20])                                                   #Insulating

plot(a.tsurf[,:20]-b.tsurf[,:20],xaxis=a.depth[,:20])
###NOT OK to run with default bottom condition

a = krc(N24=24,lbound=-1//98,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101)
plot(a.tsurf[,:20],xaxis=a.depth[,:20])                                                   #set bottom temperature

b = krc(N24=24,lbound=-2//100,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101)
plot(b.tsurf[,:20],xaxis=b.depth[,:20])                                                   #all layers at 100K

plot(a.tsurf[,:20]-b.tsurf[,:20],xaxis=a.depth[,:20])

c = krc(N24=24,lbound=0,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101)
plot(c.tsurf[,:20],xaxis=c.depth[,:20])                                                   #Insulating

plot(a.tsurf[,:20]-c.tsurf[,:20],xaxis=a.depth[,:20])

d = krc(N24=24,lbound=0.5,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101)
plot(d.tsurf[,:20],xaxis=d.depth[,:20])                                                   #Low Heat Flow
plot(a.tsurf[,:20]-d.tsurf[,:20],xaxis=a.depth[,:20])

e = krc(N24=24,lbound=50,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101)
plot(e.tsurf[,:20],xaxis=e.depth[,:20])                                                   #High Heat Flow
plot(e.tsurf,xaxis=e.depth)

f = krc(N24=24,lbound=50,KEEP="T",lat=12.,ls=0.,body="Europa",INERTIA=150.,LKofT="F",TUN8=101,JDISK=1801,N5=2160)
plot(f.tsurf[,:20],xaxis=f.depth[,:20])                                                   #Spin Longer to equilibrate
plot(f.tsurf,xaxis=f.depth)

plot(e.tsurf[,:20]-f.tsurf[,:20],xaxis=e.depth[,:20])

