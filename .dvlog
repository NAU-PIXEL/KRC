source("/Users/chaberle/Documents/GitHab/KRC/krc_python/docs/davinci/krc.dvrc")
# Load the raw bin5 file 
raw = load_bin5("/Users/chaberle/Documents/GitHab/KRC/dvkrc_good.52")
printf("Raw bin5 structure:\n")
printf("  Hours: %d\n", length(raw))
printf("  Fields: %d\n", length(raw[1]))
printf("  Block shape: %dx%dx%d\n", dim(raw[1][1])[1], dim(raw[1][1])[2], dim(raw[1][1])[3])
# Check first few values at field 1 (TSF), lat 1, season 5, case 1
printf("\nFirst 10 hours, field[1], lat[1], season[5]:\n")
i=1
while(i<=10) {
    val = raw[i][1][1,5,1]
    printf("  Hour %2d: %.2f\n", i, val)
    i = i+1
}
