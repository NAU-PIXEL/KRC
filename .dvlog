    syscall("cp -v " + t52 + " /tmp/davinci_good.t52")
    printf("\nCopied from: %s\n", workdir)
    syscall("ls -lh /tmp/davinci_good.t52")
}
printf("\nDavinci: %dx%dx%d, %.2f-%.2f K\n", dim(out.tsurf)[1], dim(out.tsurf)[2], dim(out.tsurf)[3], min(out.tsurf), max(out.tsurf))
