#!/Applications/davinci.app/Contents/Resources/bin/davinci -f

OUT = porb("Mars",force=1)
OUT = porb("Bennu",force=1)
OUT = porb("Phobos",force=1)
OUT = porb("Europa",force=1)
OUT = porb("2688_Halley",force=1)
OUT = porb("Ceres",force=1)
poledec=0
tmp=generic_porb(e=0, a=1.,i=1.30439695, node=100.47390909, peri=293.923, m=79.668,rot_per=200., polera=273.85,poledec=poledec, merid=7.7, period=4332.589, name="IdealJupiterTrojan")
OUT = porb(tmp)

name       = "Exoplanet_0001"
epoch      = 2451545.00
VisMag     = 0.
DisEarth   = 0.
e          = 0.5
a          = 1.2
rot_per    = 365.256
period     = 23.9345
Obliq      = 45.
tmp        = exo_porb(name=name,epoch=epoch,VisMag=VisMag,DisEarth=DisEarth,e=e,a=a,rot_per=rot_per,period=period,Obliq=Obliq)
OUT        = krc(lat=0.,body=tmp,PTOTAL=0.,DUSTA=0.,GRAV=0.,TAURAT=0.,ARC2_G0=0.,TFROST=0.)

y = krc(lat=12.,GD="1994-Feb-05")
x = krc(lat=12.,JD=2450075.5)
w = krc(lat=12.,DJUL=-1000.,LKEY="T")
tmp=generic_porb(e=0, a=1.,i=1.30439695, node=100.47390909, peri=293.923, m=79.668,rot_per=200., polera=273.85,poledec=poledec, merid=7.7, period=4332.589, name="IdealJupiterTrojan")
z = krc(lat=12.,body=tmp)
a = krc()
a = krc(adv_usage="generic_porb")
a = krc(KEEP="T",lat=12.)
b = krc(lat=12.,hour=2.45,T=172.3,ls=23.)

T = create(12,12,1,start=146,step=1,format=float)
b2 = krc(lat=12.,hour=2.45,T=T,ls=23.)
b = krc(lat=12.,hour=2.45,T=82.3,ls=23.,body="Europa")
c = krc(lat=12.,body="Ceres",bodyforce=1)
d = krc(lat=12.,body="Phobos",bodyforce=1)
e = krc(lat=12.,body="Europa",bodyforce=1)
f = krc(lat=12.,body="Phobos",PFlux="T")
g = krc(lat=25.,ls=90.,body="2688_Halley",N1=30)                                                    #Illegal Range values showing up

out_noflux = krc(lat=0.,INERTIA=50.,body="Phobos",LKofT="T",PFlux="F")
out_flux = krc(lat=0.,INERTIA=50.,body="Phobos",LKofT="T",PFlux="T",Lon_Hr=12.)
plot(out_noflux.tsurf[,1,1],out_flux.tsurf[,1,1],Xaxis=out_noflux.time)

out = krc(KEEP="T",lat=0.,lon=0.,thick=-0.3,INERTIA=200.,INERTIA2=1200.,LKofT="F",body="Mars",bodyforce=1) #FAILS WITH 364, not 356
plot(out.tsurf[,1,1],xaxis=out.time)

out = krc(KEEP="T",lat=0.,lon=0.,thick=0.3,INERTIA=200.,INERTIA2=1200.,LKofT="F",body="Mars")
plot(out.tsurf[,1,1],xaxis=out.time)

out = krc(lat=0.,lon=0.,INERTIA=200.,body="Jupiter",bodyforce=1,N1=40,TUN8=101)
out = krc(lat=0.,lon=0.,INERTIA=200.,body="Jupiter",bodyforce=1)
out = krc(lat=0.,lon=0.,INERTIA=200.,body="Moon",bodyforce=1)
out = krc(lat=0.,lon=0.,INERTIA=55.,body="Moon",bodyforce=1)

##########################################################################################
###MARS###################################################################################
OUT = krc(lat=25.)
labelxy("LTST" , "Temperature (K)")
plot(OUT.tsurf[,1,1],xaxis=OUT.time)
plot(OUT.tsurf[12,1,],w=4,color=4,"Dawn",OUT.tsurf[60,1,],w=4,color=1,"Noon")

#Case 1: No Date provided
OUT = krc(lat=25.)
OUT.ls[1,1,1]
OUT.anc.JDate[1,1,1]

OUT = krc(lat=12.,ls=123.)
OUT.ls[1,1,1]
OUT.anc.JDate[1,1,1]

OUT = krc(lat=12.,JD=2451575.5)   #2000-Feb-01 2451575.5 293.305
OUT.ls[1,1,1]
OUT.anc.JDate[1,1,1]

OUT = krc(lat=12.,GD="2000-Feb-01")   #2000-Feb-01 2451575.5 293.305
OUT.ls[1,1,1]
OUT.anc.JDate[1,1,1]

##########################################################################################
###EUROPA#################################################################################
OUT = krc(lat=0,INERTIA=50.,body="Europa",ALBEDO=.55,LKofT="F")
labelxy("LTST","Temperature [K]")
plot(OUT.tsurf[,1,1],xaxis=OUT.time,"70 Kieffer, No Flux",w=2,color=2)

OUT_2 = krc(lat=0.,INERTIA=50.,body="Europa",ALBEDO=0.55,PFlux="T",Lon_Hr= 12.,LKofT="F")
plot(OUT.tsurf[,1,1],w=4,color=4,"No Flux",OUT_2.tsurf[,1,1],w=4,color=1,"Default Flux")

plot(OUT.tsurf[,1,1]-OUT_2.tsurf[,1,1],w=4,color=4,"Flux effect Flux")

OUT_3 = krc(lat=0.,INERTIA=50.,body="Europa",ALBEDO=0.55,PFlux="T",BT_Avg=127.,BT_Min=127.,BT_Max=127.,Dis_AU=5.203,Geom_alb=0.52,Mut_Period=3.55,Orb_Radius=670900,Radius=670900,Lon_Hr=12.,LKofT="F")
plot(OUT.tsurf[,1,1],w=4,color=4,"No Flux",OUT_2.tsurf[,1,1],w=4,color=1,"Default Flux",OUT_3.tsurf[,1,1]+1,w=4,color=2,"User-defined Flux + 3K")
###NOT CHECKED: Visible and IR Flux tables

OUT_4 = krc(KEEP="T",bodyforce=1,lat=0.,INERTIA=045.,N1=32,body="Europa",N24=96,Eclipse="T",Eclipser="Jupiter",Ecl_Cent_Hr=12.,Bias=0.,Eclipse_Style=1.,Date=5000.)
plot(OUT_4.tsurf[,1,],xaxis=OUT_4.time,"45. Kieffer, No Flux",w=2,color=2)

OUT_4 = krc(KEEP="T",bodyforce=1,lat=0.,INERTIA=045.,N1=32,body="Phobos",N24=96,Eclipse="T",Ecl_Cent_Hr=12.,Bias=0.,Eclipse_Style=1.,Date=5000.)
plot(OUT_4.tsurf[,1,],xaxis=OUT_4.time,"45. Kieffer, No Flux",w=2,color=2)

##########################################################################################
###LTST2LMST in KRC
a    = krc(lat=12.,ls=12.)
LS   = a.ls
T    = a.tsurf
LT   = a.time

test2 = ltst2lmst(a.ls,a.tsurf,a.time)
linespoints()
plot(a.tsurf,xaxis=LT,"LTST",a.tsurf,xaxis=test2.LMST,"LMST")

a    = krc(lat=12.)
LS   = a.ls
T    = a.tsurf
LT   = a.time
test3 = ltst2lmst(a.ls,a.tsurf,a.time)
plot(a.tsurf,xaxis=LT,"LTST",a.tsurf,xaxis=test2.LMST,"LMST")

a = krc(lat=12.,LMST="T")
plot(a.tsurf[,1,1],xaxis=a.time,"LTST",a.tsurf_LMST[,1,1],xaxis=a.time,"LMST")


